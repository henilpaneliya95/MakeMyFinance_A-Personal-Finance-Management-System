# MongoDB Atlas Configuration
MONGODB_USER=your_atlas_username
MONGODB_PASS=your_atlas_password
MONGODB_HOST=your_cluster.mongodb.net
MONGODB_DATABASE_NAME=MakeMyFinance

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
RENDER_EXTERNAL_URL=https://your-service-name.onrender.com

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$

# Email Settings (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Preferred SMTP variables (used by auth OTP email service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
EMAIL_USE_TLS=True

# Auth OTP and rate limiting settings
AUTH_OTP_LENGTH=6
AUTH_OTP_EXPIRY_MINUTES=10
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_ALLOW_OTP_PREVIEW=False
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_IP_MAX=25
AUTH_RATE_LIMIT_EMAIL_MAX=8
AUTH_REQUIRE_LOGIN_OTP=True

# Google API Key (for Gemini AI features)
GOOGLE_API_KEY=your-google-api-key-here